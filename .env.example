## OpenAI (for the LLM calls)
OPENAI_API_KEY="your_openai_api_key"
OPENAI_MODEL="gpt-4o-mini"

## Gemini (for the LLM calls) - optional
## If you set OPENAI_MODEL to something like "gemini-2.5-flash-lite",
## the project will use this key.
GOOGLE_API_KEY="your_google_api_key"

## LangSmith tracing (optional but recommended for Day 4+)
## Sign up at https://smith.langchain.com, create an API key, and paste below.
## If set, Day 4+ will automatically send LLM traces to LangSmith.
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_API_KEY="your_langsmith_api_key"
LANGCHAIN_PROJECT="academic-researcher-agent"

## Local log directory (default: logs/)
AGENT_LOG_DIR="logs"

## MCP (optional): comma-separated list of MCP server URLs
## Example: MCP_SERVERS="http://localhost:3000,http://localhost:3001"
MCP_SERVERS=""

## Memory backend (default: sqlite)
## Set to "chroma" to enable semantic vector search (requires: pip install chromadb)
## "sqlite"  →  keyword LIKE search, zero extra dependencies (default)
## "chroma"  →  cosine similarity search, understands related concepts
MEMORY_BACKEND="sqlite"
